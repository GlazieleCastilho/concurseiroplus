generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  firstName String
  lastName String?
  email    String @unique
  clerkUserId String @unique
  imageUrl    String?

  createdAt  DateTime @default(now())
  updateAt  DateTime  @updatedAt

  @@map("users")
}

 /*model Course {
  id String @id @default(cuid())
